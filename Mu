Tabs.Macro:AddInput("MacroName", { Title = "File Name", Placeholder = "Enter...", Callback = function(v) _G.NattawutConfig.CurrentFile = v end })

Tabs.Macro:AddToggle("RecordBtn", { Title = "Capture Mode", Callback = function(v) _G.NattawutConfig.IsRecording = v end })

